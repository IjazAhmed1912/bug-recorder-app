# 1. Copy this file: cp .env.example .env.local
# 2. Open Firebase Console → your project → Project settings (gear) → General → Your apps → Web app
# 3. Paste each value from the firebaseConfig object (or the SDK snippet) into the matching VITE_* line below.
# Vite loads .env.local automatically; do not commit .env.local to Git.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
